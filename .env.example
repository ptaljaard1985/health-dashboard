# Garmin Health Sync - Environment Variables
# ============================================
# Copy this file to .env and fill in your credentials
#
# IMPORTANT: Never commit .env to version control!
#            Only .env.example should be shared.

# Garmin Connect Credentials
# --------------------------
# Your Garmin Connect login email and password
GARMIN_EMAIL=your.email@example.com
GARMIN_PASSWORD=your_garmin_password

# Garmin Token Store (optional, preferred for CI)
# ------------------------------------------------
# Base64-encoded Garth token data, or path to token directory.
# If set, token-based auth is used instead of email/password.
# Generate tokens by logging in locally, then export with garth.
# GARMINTOKENS=

# Sync Settings
# -------------
# How many days back to sync (default: 7)
DAYS_TO_SYNC=7

# Anthropic API Key (for AI dashboard summary)
# ---------------------------------------------
ANTHROPIC_API_KEY=your_anthropic_api_key

# Telegram Bot (for daily health notifications)
# -----------------------------------------------
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
